# ============================================
# FoodDash Backend Configuration (MySQL)
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
# Options: development, production, test
# Use 'development' for local testing

PORT=5000
# Express server port
# Must not conflict with other services

CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Comma-separated list of allowed frontend origins
# For production: https://yourdomain.com,https://www.yourdomain.com

# ============================================
# MYSQL DATABASE CONFIGURATION
# ============================================
# These values must match your MySQL setup

DB_HOST=localhost
# MySQL server address
# localhost: Local development
# your-ip.com or server.example.com: Remote server

DB_PORT=3306
# MySQL port (default 3306)
# Standard port for MySQL

DB_NAME=fooddash
# Database name
# Create this database first: CREATE DATABASE fooddash;

DB_USER=root
# MySQL username
# DEVELOPMENT ONLY: use 'root'
# PRODUCTION: create dedicated user with minimal permissions

DB_PASSWORD=your_mysql_password
# MySQL password
# For local: often blank or 'root'
# For production: use strong password (min 12 chars, mixed case, numbers, symbols)

DB_CONNECTION_LIMIT=10
# MySQL connection pool size
# Development: 5-10
# Production: 20-50 (based on expected concurrent users)

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=replace_with_a_long_secret_at_least_32_chars
# Secret key for signing JWT tokens
# MUST be at least 32 characters
# Generate: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER share this secret

JWT_EXPIRES_IN=7d
# JWT token expiration
# Options: 15m, 1h, 7d, 30d
# Shorter = more secure, longer = better UX
# Recommended: 7d for access tokens

BCRYPT_ROUNDS=10

# Development default is 2000 requests per 15 minutes.
# Production default is 200 requests per 15 minutes.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=2000
# Password hashing strength
# Range: 8-14 (higher = more secure but slower)
# 10 recommended (balanced security & performance)
# Each additional round ~doubles processing time

# ============================================
# ADMIN ACCOUNT SETUP
# ============================================
# Used for initial admin creation: npm run db:create-admin
# Set these BEFORE running db:create-admin

ADMIN_EMAIL=your_admin_email@example.com
# Admin login email
# Must be unique, valid email format
# Example: admin@fooddash.com

ADMIN_PASSWORD=your_private_admin_password
# Admin login password
# Must be at least 8 characters
# Store securely, not in code
# Example: SecurePass123!

ADMIN_NAME=FoodDash Admin
# Display name for admin
# Example: John Doe
