{
  "name": "fooddash-backend",
  "version": "1.0.0",
  "description": "FoodDash food delivery REST API built with Node.js, Express, and MySQL.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node scripts/run-sql-file.js ../database/migrations/001_create_fooddash_schema.sql",
    "db:admin": "node scripts/run-sql-file.js ../database/migrations/002_create_admin_system.sql",
    "db:restaurant-auth": "node scripts/run-sql-file.js ../database/migrations/003_add_restaurant_owner_auth.sql",
    "db:addresses": "node scripts/run-sql-file.js ../database/migrations/004_create_customer_addresses.sql",
    "db:create-admin": "node scripts/create-admin.js",
    "db:seed": "node scripts/run-sql-file.js ../database/seeds/001_seed_fooddash.sql",
    "test": "jest",
    "lint": "node --check src/server.js"
  },
  "keywords": [
    "food-delivery",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
